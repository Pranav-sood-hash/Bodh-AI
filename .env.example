# ─── DATABASE ─────────────────────────
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ─── REDIS (Upstash) ──────────────────
REDIS_URL="rediss://default:password@region.upstash.io:6379"

# ─── SERVER ───────────────────────────
PORT=5000
NODE_ENV=production
CLIENT_URL=https://yourdomain.com

# ─── JWT ──────────────────────────────
JWT_ACCESS_SECRET=generate_with_node_crypto_64_chars
JWT_REFRESH_SECRET=generate_with_node_crypto_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── GOOGLE OAUTH ─────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback

# ─── GMAIL SMTP ───────────────────────
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# ─── CLOUDINARY ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── ENCRYPTION ───────────────────────
ENCRYPTION_KEY=exactly_32_characters_here
ENCRYPTION_IV=exactly_16_chars

# ─── AI PROVIDERS ───────────────────────
DEFAULT_AI_PROVIDER=GROQ
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key
